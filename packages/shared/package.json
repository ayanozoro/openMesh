{
  "name": "@openmesh/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, constants, and utilities for OpenMesh",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
