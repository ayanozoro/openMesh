{
  "name": "@openmesh/server",
  "version": "0.1.0",
  "private": true,
  "description": "OpenMesh signaling and coordination server",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@openmesh/shared": "*",
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "mongoose": "^8.9.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2"
  }
}
